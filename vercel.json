{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "**/*.{html,css,txt,xml,json,ico,png,svg,webmanifest}", "use": "@vercel/static" },
    { "src": "assets/**/*.js", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY",
        "X-XSS-Protection": "1; mode=block"
      },
      "continue": true
    },

    { "src": "/picks/best-headphones/?", "status": 308, "headers": { "Location": "/blog/best-headphones" } },
    { "src": "/picks/vegas-weekend-trips/?", "status": 308, "headers": { "Location": "/blog/vegas-weekend-trips" } },
    { "src": "/picks/smart-shopping/?", "status": 308, "headers": { "Location": "/blog/warehouse-clubs-worth-it" } },

    { "src": "/deals/?", "dest": "/deals/index.html" },
    { "src": "/blog/?", "dest": "/blog/index.html" },
    { "src": "/blog/best-headphones/?", "dest": "/blog/best-headphones/index.html" },
    { "src": "/blog/vegas-weekend-trips/?", "dest": "/blog/vegas-weekend-trips/index.html" },
    { "src": "/blog/warehouse-clubs-worth-it/?", "dest": "/blog/warehouse-clubs-worth-it/index.html" },
    { "src": "/blog/how-we-verify-deals/?", "dest": "/blog/how-we-verify-deals/index.html" },
    { "src": "/about/?", "dest": "/about/index.html" },
    { "src": "/affiliate-disclosure/?", "dest": "/affiliate-disclosure/index.html" },
    { "src": "/privacy/?", "dest": "/privacy/index.html" },

    { "src": "/api/post-tweet", "dest": "/api/post-tweet.js" },
    { "src": "/go/(?<slug>[^/]+)", "dest": "/api/go/[slug].js" },

    { "handle": "filesystem" },

    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
